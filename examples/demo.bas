10 REM Galaxian BASIC Demo - bouncing sprites and scrolling
20 CLS
30 PRINT 8, 10, "GALAXIAN BASIC"
40 PRINT 6, 12, "READY"
50 PRINT 5, 15, "INPUT OK"
60 PRINT 2, 20, "WATCHDOG OK"
70 FOR X = 4 TO 27
80   POKE X, 24, X
90   COLOR X, 2
100 NEXT X
110 LET Y0 = 4
120 LET Y1 = 12
130 LET Y2 = 20
140 LET DY0 = 1
150 LET DY1 = 1
160 LET DY2 = 255
170 LET S = 0
180 LET F = 0
190 REM Main loop
200 LET F = F + 1
210 IF F < 4 THEN GOTO 280
220 LET F = 0
230 LET Y0 = Y0 + DY0
240 IF Y0 >= 26 THEN GOTO 250
245 IF Y0 <= 2 THEN GOTO 255
246 GOTO 260
250 LET Y0 = 26
251 LET DY0 = 255
252 GOTO 260
255 LET Y0 = 2
256 LET DY0 = 1
260 LET Y1 = Y1 + DY1
261 IF Y1 >= 24 THEN GOTO 262
265 IF Y1 <= 4 THEN GOTO 266
267 GOTO 270
262 LET Y1 = 24
263 LET DY1 = 255
264 GOTO 270
266 LET Y1 = 4
268 LET DY1 = 1
270 LET Y2 = Y2 + DY2
271 IF Y2 >= 22 THEN GOTO 272
275 IF Y2 <= 6 THEN GOTO 276
277 GOTO 280
272 LET Y2 = 22
273 LET DY2 = 255
274 GOTO 280
276 LET Y2 = 6
278 LET DY2 = 1
280 SPRITE 0, 32, Y0*8, 24, 1
290 SPRITE 1, 64, Y1*8, 24, 2
300 SPRITE 2, 96, Y0*8, 24, 3
310 SPRITE 3, 128, Y1*8, 24, 4
320 SPRITE 4, 160, Y2*8, 24, 5
330 SPRITE 5, 192, Y0*8, 24, 6
340 SPRITE 6, 224, Y1*8, 24, 7
350 HIDE 7
360 LET S = S + 1
370 FOR C = 4 TO 27 STEP 2
380   SCROLL C, S
390 NEXT C
400 WAIT 1
410 GOTO 200
