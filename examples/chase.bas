10 REM Chase demo - joystick moves player, enemy moves on its own
20 CLS
30 PRINT 6, 0, "CHASE - USE JOYSTICK"
40 LET PX = 100
50 LET PY = 120
60 LET EX = 80
70 LET EY = 80
80 LET EDX = 2
90 LET EDY = 1
100 REM Main loop
110 LET PX = PX + JOY(1)
120 LET PX = PX - JOY(0)
130 LET PY = PY + JOY(3)
140 LET PY = PY - JOY(2)
150 IF PX < 8 THEN GOTO 170
160 GOTO 190
170 LET PX = 8
180 GOTO 190
190 IF PX > 216 THEN GOTO 210
200 GOTO 230
210 LET PX = 216
220 GOTO 230
230 IF PY < 8 THEN GOTO 250
240 GOTO 270
250 LET PY = 8
260 GOTO 270
270 IF PY > 240 THEN GOTO 290
280 GOTO 310
290 LET PY = 240
300 GOTO 310
310 LET EX = EX + EDX
320 IF EX >= 216 THEN GOTO 340
330 GOTO 370
340 LET EX = 216
350 LET EDX = 255
360 GOTO 370
370 IF EX <= 8 THEN GOTO 390
380 GOTO 420
390 LET EX = 8
400 LET EDX = 2
410 GOTO 420
420 LET EY = EY + EDY
430 IF EY >= 240 THEN GOTO 450
440 GOTO 480
450 LET EY = 240
460 LET EDY = 255
470 GOTO 480
480 IF EY <= 8 THEN GOTO 500
490 GOTO 530
500 LET EY = 8
510 LET EDY = 1
520 GOTO 530
530 SPRITE 0, PX, PY, 24, 1
540 SPRITE 1, EX, EY, 24, 2
550 HIDE 2
560 WAIT 1
570 GOTO 110
