10 REM Chase demo - joystick moves player, enemy moves on its own
20 CLS
30 PRINT 6, 0, "CHASE - USE JOYSTICK"
40 LET PX = 100
50 LET PY = 120
60 LET EX = 80
70 LET EY = 80
80 LET EDX = 2
90 LET EDY = 1
100 REM Main loop
110 LET PX = PX + JOY(1)
120 LET PX = PX - JOY(0)
130 LET PY = PY + JOY(3)
140 LET PY = PY - JOY(2)
150 IF PX < 8 THEN GOTO 160
155 GOTO 165
160 LET PX = 8
161 GOTO 165
165 IF PX > 216 THEN GOTO 170
167 GOTO 175
170 LET PX = 216
171 GOTO 175
175 IF PY < 8 THEN GOTO 180
177 GOTO 185
180 LET PY = 8
181 GOTO 185
185 IF PY > 240 THEN GOTO 190
187 GOTO 195
190 LET PY = 240
191 GOTO 195
195 LET EX = EX + EDX
196 IF EX >= 216 THEN GOTO 198
197 GOTO 201
198 LET EX = 216
199 LET EDX = 255
200 GOTO 201
201 IF EX <= 8 THEN GOTO 203
202 GOTO 206
203 LET EX = 8
204 LET EDX = 2
205 GOTO 206
206 LET EY = EY + EDY
207 IF EY >= 240 THEN GOTO 209
208 GOTO 212
209 LET EY = 240
210 LET EDY = 255
211 GOTO 212
212 IF EY <= 8 THEN GOTO 214
213 GOTO 220
214 LET EY = 8
215 LET EDY = 1
216 GOTO 220
220 SPRITE 0, PX, PY, 24, 1
230 SPRITE 1, EX, EY, 24, 2
240 HIDE 2
250 WAIT 1
260 GOTO 110
