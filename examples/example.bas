780 REM draw_explosion(0xc0, 12) - putshape pattern
790 COLOR 12, 2
800 COLOR 13, 2
810 COLOR 14, 2
820 COLOR 15, 2
830 FOR X = 0 TO 3
840 LET O = 192+X*16
850 PUTSHAPE X*5, 12, O+8
860 PUTSHAPE X*5, 14, O+12
870 PUTSHAPE X*5+2, 12, O
880 PUTSHAPE X*5+2, 14, O+4
890 NEXT X
900 PRINT 7, 0, "HELLO@WORLD@123"
910 REM draw_corners - vram[2][0],[2][31],[29][0],[29][31] -> putchar(27,0),(27,31),(0,0),(0,31)
920 LET C0 = C0+1
930 POKE 27, 0, C0
940 POKE 27, 31, C0
950 POKE 0, 0, C0
960 POKE 0, 31, C0
970 REM vcolumns[1].attrib = frame
980 COLOR 1, F
990 REM draw_missiles - sprites + missiles (matches example.c)
1000 FOR I = 0 TO 7
1010 SPRITE I, I*32+F, I*24+F, 24, I+1
1020 MISSILE I, I*16+F, I+24
1030 NEXT I
1040 LET F = F+1
1050 WAIT 1
1060 GOTO 50
