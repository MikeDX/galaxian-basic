10 REM Example demo - converted from example.c
20 REM Draws all chars, sprites, explosion, text, missiles, corners
30 CLS
40 LET F = 0
50 REM draw_all_chars - 256 tiles in 8 rows (y=2 to 9), x=i&31 y=(i>>5)+2
60 FOR I = 0 TO 31
70 POKE I, 2, I
80 NEXT I
90 COLOR 2, F+2
100 FOR I = 0 TO 31
110 POKE I, 3, I+32
120 NEXT I
130 COLOR 3, F+3
140 FOR I = 0 TO 31
150 POKE I, 4, I+64
160 NEXT I
170 COLOR 4, F+4
180 FOR I = 0 TO 31
190 POKE I, 5, I+96
200 NEXT I
210 COLOR 5, F+5
220 FOR I = 0 TO 31
230 POKE I, 6, I+128
240 NEXT I
250 COLOR 6, F+6
260 FOR I = 0 TO 31
270 POKE I, 7, I+160
280 NEXT I
290 COLOR 7, F+7
300 FOR I = 0 TO 31
310 POKE I, 8, I+192
320 NEXT I
330 COLOR 8, F+8
340 FOR I = 0 TO 31
350 POKE I, 9, I+224
360 NEXT I
370 COLOR 9, F+9
380 REM vcolumns[y].scroll = frame for rows 2-9 (matches improved example.c)
390 SCROLL 2, F
400 SCROLL 3, F
410 SCROLL 4, F
420 SCROLL 5, F
430 SCROLL 6, F
440 SCROLL 7, F
450 SCROLL 8, F
460 SCROLL 9, F
470 REM draw_sprites(0x30, 18)
480 WAIT 1
490 COLOR 18, 1
500 COLOR 19, 1
510 FOR I = 0 TO 7
520 PUTSHAPE I*3, 18, 48+I*4
530 NEXT I
540 REM draw_sprites(0x50, 21)
550 COLOR 21, 1
560 COLOR 22, 1
570 FOR I = 0 TO 7
580 PUTSHAPE I*3, 21, 80+I*4
590 NEXT I
600 REM draw_sprites(0x70, 24)
610 COLOR 24, 1
620 COLOR 25, 1
630 FOR I = 0 TO 7
640 PUTSHAPE I*3, 24, 112+I*4
650 NEXT I
660 REM draw_sprites(0xa0, 27)
670 COLOR 27, 1
680 COLOR 28, 1
690 FOR I = 0 TO 7
700 PUTSHAPE I*3, 27, 160+I*4
710 NEXT I
720 REM draw_sprites(0x0, 29)
730 COLOR 29, 1
740 COLOR 30, 1
750 FOR I = 0 TO 7
760 PUTSHAPE I*3, 29, I*4
